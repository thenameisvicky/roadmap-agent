{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunReport",
  "type": "object",
  "required": ["scenario_id", "mode", "provider", "model", "steps", "final_answer", "success"],
  "properties": {
    "scenario_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["live"] },
    "provider": { "type": "string", "description": "e.g. openai, anthropic, google" },
    "model": { "type": "string", "description": "model id used for the run" },
    "success": { "type": "boolean" },
    "final_answer": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_index",
          "tokens_used",
          "token_budget",
          "context_included",
          "context_evicted",
          "action"
        ],
        "properties": {
          "step_index": { "type": "integer" },
          "tokens_used": { "type": "integer" },
          "token_budget": { "type": "integer" },
          "context_included": { "type": "array", "items": { "type": "string" } },
          "context_evicted": { "type": "array", "items": { "type": "string" } },
          "context_decisions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["reason"],
              "properties": {
                "reason": { "type": "string" },
                "block": { "type": "string" }
              }
            }
          },
          "action": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["tool_call", "finish", "guardrail_block", "error"] },
              "tool": { "type": "string" },
              "arguments": { "type": "object" },
              "result_summary": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
